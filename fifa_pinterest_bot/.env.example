# ============================================
# FIFA Pinterest Bot — Environment Variables (TEMPLATE)
# ============================================

# --- Google Gemini API ---
# Multiple keys supported (comma-separated). 
GEMINI_API_KEYS=your_gemini_api_key_here

# --- SiliconFlow API ---
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# --- Pinterest API ---
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token
PINTEREST_REFRESH_TOKEN=your_refresh_token
PINTEREST_APP_ID=your_app_id
PINTEREST_APP_SECRET=your_app_secret

# --- Pinterest Board IDs ---
PINTEREST_BOARD_ULTIMATE_GUIDE=your_id
PINTEREST_BOARD_HOST_CITIES=your_id
PINTEREST_BOARD_QUALIFIERS=your_id
PINTEREST_BOARD_HISTORY=your_id
PINTEREST_BOARD_TACTICS=your_id
